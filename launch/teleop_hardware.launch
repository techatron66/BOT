<launch>
  <!-- Teleop control for real hardware -->
  
  <!-- Include hardware bringup -->
  <include file="$(find articubot_one)/launch/hardware_bringup.launch"/>
  
  <!-- Teleop keyboard node -->
  <node pkg="teleop_twist_keyboard" type="teleop_twist_keyboard.py" 
        name="teleop_keyboard" output="screen">
    <param name="speed" value="0.3"/>      <!-- Linear speed m/s -->
    <param name="turn" value="0.5"/>       <!-- Angular speed rad/s -->
  </node>
  
</launch>
