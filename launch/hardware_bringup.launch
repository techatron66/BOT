<launch>
  <!-- Hardware bringup for real robot (no encoders) -->
  
  <!-- 1. Arduino Serial Node -->
  <!-- Change /dev/ttyACM0 to match your Arduino port -->
  <node pkg="rosserial_python" type="serial_node.py" name="arduino_bridge" output="screen">
    <param name="port" value="/dev/ttyACM0"/>
    <param name="baud" value="57600"/>
  </node>
  
  <!-- 2. Robot State Publisher (for TF) -->
  <!-- Uses the same URDF as simulation -->
  <param name="robot_description" command="$(find xacro)/xacro $(find articubot_one)/urdf/robot.urdf.xacro"/>
  
  <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher"/>
  
  <!-- 3. Joint State Publisher (for visualization) -->
  <!-- Since no encoders, this publishes zero positions -->
  <node pkg="joint_state_publisher" type="joint_state_publisher" name="joint_state_publisher">
    <param name="use_gui" value="false"/>
  </node>
  
  <!-- 4. Static transform for odom (hack for no encoders) -->
  <!-- Publishes identity transform so RViz doesn't complain -->
  <node pkg="tf" type="static_transform_publisher" name="odom_to_base_link" 
        args="0 0 0 0 0 0 odom base_link 50"/>
  
  <!-- 5. RViz -->
  <node pkg="rviz" type="rviz" name="rviz" 
        args="-d $(find articubot_one)/rviz/robot_view.rviz"/>
  
</launch>
