<launch>
  <!-- ========================================================== -->
  <!-- Gazebo Simulation Launch with Obstacles World              -->
  <!-- Spawns the robot in the obstacles.world environment          -->
  <!-- ========================================================== -->

  <!-- Launch arguments -->
  <arg name="world" default="$(find articubot_one)/worlds/obstacles.world"/>
  <arg name="paused" default="false"/>
  <arg name="use_sim_time" default="true"/>
  <arg name="gui" default="true"/>
  <arg name="headless" default="false"/>
  <arg name="debug" default="false"/>
  <arg name="x_pos" default="0.0"/>
  <arg name="y_pos" default="0.0"/>
  <arg name="z_pos" default="0.1"/>

  <!-- Set use_sim_time parameter -->
  <param name="/use_sim_time" value="$(arg use_sim_time)"/>

  <!-- Load robot description -->
  <param name="robot_description" 
         command="$(find xacro)/xacro $(find articubot_one)/urdf/robot.urdf.xacro"/>

  <!-- Robot State Publisher -->
  <node pkg="robot_state_publisher" type="robot_state_publisher" 
        name="robot_state_publisher" output="screen">
    <param name="publish_frequency" type="double" value="50.0"/>
  </node>

  <!-- Joint State Publisher (for Gazebo, publishes from simulation) -->
  <node pkg="joint_state_publisher" type="joint_state_publisher" 
        name="joint_state_publisher" output="screen"/>

  <!-- Launch Gazebo with specified world -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(arg world)"/>
    <arg name="paused" value="$(arg paused)"/>
    <arg name="use_sim_time" value="$(arg use_sim_time)"/>
    <arg name="gui" value="$(arg gui)"/>
    <arg name="headless" value="$(arg headless)"/>
    <arg name="debug" value="$(arg debug)"/>
  </include>

  <!-- Spawn robot in Gazebo -->
  <node pkg="gazebo_ros" type="spawn_model" name="spawn_robot" 
        output="screen"
        args="-param robot_description
              -urdf
              -model articubot_one
              -x $(arg x_pos)
              -y $(arg y_pos)
              -z $(arg z_pos)"/>

  <!-- Launch teleop for manual driving -->
  <node pkg="teleop_twist_keyboard" type="teleop_twist_keyboard.py" 
        name="teleop_keyboard" output="screen">
    <param name="speed" value="0.3"/>
    <param name="turn" value="0.5"/>
    <remap from="cmd_vel" to="/cmd_vel"/>
  </node>

  <!-- RViz with robot view -->
  <node pkg="rviz" type="rviz" name="rviz" 
        args="-d $(find articubot_one)/rviz/robot_with_lidar.rviz"/>

</launch>
